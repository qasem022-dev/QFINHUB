      "any noindex/canonical/delete/redirect",
      "Validate Fix in GSC",
      "Google Indexing API",
      "contact form submission",
      "paid tools or services",
      "paid links",
      "fake traffic"
    ],
    "soft_blocks": [
      "deploying (allowed only if safe changes made)",
      "modifying sitemap",
      "GSC UI Request Indexing (allowed max 5 high-value pages only)"
    ]
  },
  "mode_override": "CONTENT_CLICK_MODE (first runs focus on getting first click)",
