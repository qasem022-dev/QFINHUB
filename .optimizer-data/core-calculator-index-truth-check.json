  "correction_note": "Previous classification was WRONG. INDEXING_ALLOWED means Google is permitted to index — it is NOT a 'not indexed' signal. The authoritative field is coverageState='Submitted and indexed', which confirms index presence.",

  "classification_rules_corrected": {
    "A_confirmed_indexed": "coverageState = 'Submitted and indexed' AND indexingState = 'INDEXING_ALLOWED' AND verdict = PASS AND canonical matches. INDEXING_ALLOWED is the NORMAL state for indexed pages.",
    "B_crawled_not_indexed": "coverageState = 'Crawled — currently not indexed' ONLY. Do NOT use indexingState alone.",
    "C_discovered_not_crawled": "coverageState = 'Discovered — currently not indexed' ONLY.",
    "D_unknown": "API returns no crawl data or 'URL is unknown to Google'.",
    "E_inconclusive": "API fields conflict with each other.",
